{
  "name": "vscode-syma",
  "displayName": "Syma Language Support",
  "description": "Syntax highlighting, snippets, and language intelligence for the Syma symbolic programming language",
  "version": "0.2.0",
  "publisher": "syma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://code.tanganke.com/syma/vscode-syma"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "syma",
    "symbolic",
    "wolfram",
    "mathematica",
    "pattern-matching",
    "language"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:syma",
    "onDebugResolve:syma",
    "onDebugInitialConfigurations"
  ],
  "contributes": {
    "languages": [
      {
        "id": "syma",
        "aliases": [
          "Syma",
          "syma"
        ],
        "extensions": [
          ".syma"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "syma",
        "scopeName": "source.syma",
        "path": "./syntaxes/syma.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "syma",
        "path": "./snippets/syma.json"
      }
    ],
    "configuration": {
      "title": "Syma",
      "properties": {
        "syma.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Syma language server binary (optional, uses bundled server by default)"
        },
        "syma.server.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Syma language server"
        },
        "syma.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable syntax diagnostics from the language server"
        },
        "syma.diagnostics.delay": {
          "type": "integer",
          "default": 500,
          "description": "Delay (ms) before running diagnostics after a change"
        }
      }
    },
    "commands": [
      {
        "command": "syma.runFile",
        "title": "Syma: Run File"
      }
    ],
    "debuggers": [
      {
        "type": "syma",
        "label": "Syma Debug",
        "languages": [
          "syma"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .syma file to debug",
                "default": "${file}"
              },
              "symaPath": {
                "type": "string",
                "description": "Path to the syma binary",
                "default": "syma"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Additional arguments to pass to syma"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "syma",
            "request": "launch",
            "name": "Run Syma File",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Syma: Launch",
            "description": "Launch a Syma program in the debugger",
            "body": {
              "type": "syma",
              "request": "launch",
              "name": "Run Syma File",
              "program": "${file}"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "vscode-languageclient": "^9.0.0",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.0"
  }
}
